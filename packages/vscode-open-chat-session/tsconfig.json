{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2023",
    "outDir": "out",
    "lib": ["ES2023"],
    "types": ["node"],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "out"]
}
